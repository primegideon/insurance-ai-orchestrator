# ============================================================
# Insurance AI Orchestrator — environment variable reference
# Copy this file to .env and fill in your real values.
# Never commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# IBM watsonx.ai  (required for the AI risk evaluation engine)
# ------------------------------------------------------------
WATSONX_API_KEY=your-ibm-cloud-api-key
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your-watsonx-project-id

# ------------------------------------------------------------
# Supabase  (required for evaluation logging AND auth)
#
# SUPABASE_URL  – the "Project URL" shown in
#                 Supabase Dashboard → Project Settings → API
#
# SUPABASE_KEY  – Backend (backend/.env):
#                   Use the "service_role" secret key so the server
#                   can write to the evaluations table freely.
#                   Keep this value strictly server-side — never expose it.
#
#                 Frontend (frontend env / st.secrets):
#                   Use the "anon" public key. The frontend only needs
#                   to call Supabase Auth (sign-in / sign-out) — it never
#                   writes to the database directly.
# ------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# SUPABASE_JWT_SECRET is NOT required if your project uses ES256 signing
# (Supabase projects created after ~2024 use asymmetric ES256 by default).
# The backend fetches the public key automatically from:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
# No secret needed — only SUPABASE_URL above is required for this.
